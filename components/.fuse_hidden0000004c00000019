            <ul
              className={`mt-6 space-y-3 ${
                service.featured ? "md:mt-0 md:w-1/2 md:self-center" : ""
              }`}
            >
              {service.features.map((f) => (
                <Feature key={f}>{f}</Feature>
              ))}
            </ul>
          </motion.article>
        ))}
      </motion.div>
    </section>
