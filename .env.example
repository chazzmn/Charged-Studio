# Charged Studio — environment variables
# Copy this file to `.env.local` for local dev, and add the same keys in
# Vercel → Project → Settings → Environment Variables for production.
#
# The contact form (/api/contact) picks a sender in this order:
#   1. RESEND_API_KEY set      → sends via Resend (recommended, fully owned)
#   2. else FORMSPREE_ENDPOINT → forwards to your existing Formspree form
#   3. else                    → form returns a "not set up yet" message
#
# So you can ship today with Formspree and switch to Resend later by just
# adding RESEND_API_KEY — no code changes.

# --- Option A: Resend (https://resend.com) -------------------------------
# Free account → API Keys → create one. Paste it here.
RESEND_API_KEY=

# Who the lead emails are sent FROM. Until you verify chargedstudio.co.uk in
# Resend, use the test sender below. After verifying, switch to your domain:
#   CONTACT_FROM="Charged Studio <hello@chargedstudio.co.uk>"
CONTACT_FROM="Charged Studio <onboarding@resend.dev>"

# Where leads are delivered TO (your inbox).
CONTACT_TO="hello@chargedstudio.co.uk"

# --- Option B: Formspree (works today, no DNS) ---------------------------
# Your existing form endpoint, e.g. https://formspree.io/f/abcdwxyz
FORMSPREE_ENDPOINT=

# --- Analytics (added later) ---------------------------------------------
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
